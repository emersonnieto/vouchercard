generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum FlightDirection {
  OUTBOUND
  RETURN
}

enum SubscriptionPlan {
  MONTHLY
  SEMIANNUAL
  ANNUAL
}

enum SubscriptionStatus {
  PENDING
  CHECKOUT_CREATED
  CHECKOUT_EXPIRED
  ACTIVE
  PAST_DUE
  CANCELED
}

model Agency {
  id              String               @id @default(uuid())
  name            String
  slug            String               @unique
  phone           String?
  email           String?
  contactName     String?
  document        String?
  postalCode      String?
  street          String?
  addressNumber   String?
  complement      String?
  neighborhood    String?
  city            String?
  state           String?
  website         String?
  asaasCustomerId String?              @unique
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @default(now()) @updatedAt

  isActive        Boolean              @default(true)
  logoUrl         String?
  primaryColor    String?

  subscriptions   AgencySubscription[]
  vouchers        Voucher[]
  users           User[]
}

model User {
  id           String   @id @default(uuid())
  agencyId     String
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("ADMIN")
  createdAt    DateTime @default(now())

  agency Agency @relation(fields: [agencyId], references: [id])
}

model Voucher {
  id                String   @id @default(uuid())
  agencyId          String
  publicCode        String   @unique
  reservationCode   String
  webCheckinCode    String?
  clientName        String
  tripDestination   String?
  itinerarySuggestion String?
  itineraryGeneratedAt DateTime?
  itineraryModel    String?
  insuranceProvider String?
  insurancePhone    String?
  insuranceEmail    String?
  additionalNotes   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  agency   Agency  @relation(fields: [agencyId], references: [id])
  flights  Flight[]
  hotel    Hotel?
  transfer Transfer?
  tours    Tour[]

  @@unique([agencyId, reservationCode])
}

model Flight {
  id               String          @id @default(uuid())
  voucherId        String
  direction        FlightDirection @default(OUTBOUND)
  segmentOrder     Int             @default(0)
  flightNumber     String?
  flightDate       String?
  departureTime    String?
  arrivalTime      String?
  embarkAirport    String?
  disembarkAirport String?

  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  @@index([voucherId])
  @@index([voucherId, direction, segmentOrder])
}

model Hotel {
  id           String   @id @default(uuid())
  voucherId    String   @unique
  hotelName    String
  email        String?
  phones       String[] @default([])
  postalCode   String?
  street       String?
  hotelNumber  String?
  neighborhood String?
  city         String?
  state        String?
  country      String?
  nights       Int?
  checkInAt    String?
  checkOutAt   String?
  mealPlan     String?
  roomType     String?
  checkInTime  String?
  checkOutTime String?

  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
}

model Transfer {
  id            String @id @default(uuid())
  voucherId     String @unique
  receptiveName String?

  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
}

model Tour {
  id            String @id @default(uuid())
  voucherId     String
  sortOrder     Int    @default(0)
  tourDate      String?
  departureTime String?
  location      String?
  receptiveName String?

  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  @@index([voucherId])
  @@index([voucherId, sortOrder])
}

model AgencySubscription {
  id                     String             @id @default(uuid())
  agencyId               String
  publicToken            String             @unique
  provider               String             @default("ASAAS")
  plan                   SubscriptionPlan
  status                 SubscriptionStatus @default(PENDING)
  billingCycleMonths     Int                @default(1)
  commitmentMonths       Int                @default(1)
  price                  Decimal            @db.Decimal(10, 2)
  currency               String             @default("BRL")
  checkoutUrl            String?
  providerCustomerId     String?
  providerCheckoutId     String?            @unique
  providerSubscriptionId String?            @unique
  latestPaymentId        String?
  checkoutExpiresAt      DateTime?
  activatedAt            DateTime?
  canceledAt             DateTime?
  lastEventAt            DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId, createdAt])
  @@index([providerCustomerId])
  @@index([providerSubscriptionId])
}

model BillingWebhookEvent {
  id         String   @id
  provider   String
  event      String
  payload    Json
  receivedAt DateTime @default(now())

  @@index([provider, event])
}

model BillingLegalAcceptance {
  id             String   @id @default(uuid())
  kind           String
  email          String
  agencyId       String?
  subscriptionId String?
  publicToken    String?
  statementText  String
  statementHash  String
  termsTitle     String
  termsVersion   String
  termsHash      String
  termsText      String
  privacyTitle   String
  privacyVersion String
  privacyHash    String
  privacyText    String
  bundleHash     String
  acceptedAt     DateTime @default(now())
  ipAddress      String?
  userAgent      String?
  acceptLanguage String?
  requestPath    String?
  origin         String?
  referer        String?

  @@index([email, acceptedAt])
  @@index([agencyId, acceptedAt])
  @@index([subscriptionId])
  @@index([publicToken])
  @@index([kind, acceptedAt])
}

model AppRateLimit {
  key       String   @id
  count     Int
  resetAt   DateTime @map("reset_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@map("app_rate_limits")
}
